{
  "name": "knight-strike",
  "version": "1.3.0",
  "description": "Knight Strike / 知識戰爭 — web remake of 国家大作戦 (lm_exp)",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22 <23"
  },
  "packageManager": "pnpm@8.3.1",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:pages": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "playtest": "tsx src/playtest/cli.ts",
    "playtest:v2": "tsx src/playtest/v2/cli.ts",
    "smoke": "node scripts/smoke/run.mjs",
    "balance": "tsx src/playtest/balance-check.ts",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "prepare": "lefthook install || true"
  },
  "dependencies": {
    "gsap": "^3.14.2",
    "pixi.js": "^8.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.12.0",
    "@vitest/coverage-v8": "^2.0.0",
    "@vitest/ui": "^2.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "lefthook": "^1.6.0",
    "prettier": "^3.0.0",
    "tsx": "^4.8.1",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^8.0.1",
    "vitest": "^2.0.0"
  }
}
